{
  "name": "mrc-baltic-cruise",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.16.0",
  "engines": {
    "pnpm": ">=10.16.0",
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --port 5151",
    "build": "tsc -b && vite build",
    "lint:write": "biome lint --write ./src",
    "lint:write:unsafe": "biome lint --write --unsafe ./src",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "worker:deploy": "cd workers/live-track-api && npx wrangler@latest deploy",
    "worker:dev": "cd workers/live-track-api && npx wrangler@latest dev",
    "worker:tail": "cd workers/live-track-api && npx wrangler@latest tail"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
